# ──────────────────────────────────────────────
# REQUIRED — You must change these values
# ──────────────────────────────────────────────

# Database password — generate with: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME

# Odoo master password (for creating/managing databases)
# Generate with: openssl rand -base64 24
ODOO_ADMIN_PASSWORD=CHANGE_ME

# ──────────────────────────────────────────────
# DOMAIN — Leave empty for local/IP access
# ──────────────────────────────────────────────
# If you have a domain name, set it here (no www, no https):
#   DOMAIN=ephem.health.gov.ye
# If you don't have a domain (local VM, testing, personal machine):
#   Leave it empty — the system will be accessible via http://YOUR_IP
DOMAIN=

# Email for SSL certificate (only needed if DOMAIN is set)
SSL_EMAIL=

# ──────────────────────────────────────────────
# OPTIONAL — Defaults work for most setups
# ──────────────────────────────────────────────

POSTGRES_USER=odoo
POSTGRES_DB=postgres

# Set to False after creating all your databases
ODOO_LIST_DB=True

# Database filter for subdomain routing (e.g. %d)
ODOO_DBFILTER=

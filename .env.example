# ──────────────────────────────────────────────
# REQUIRED — You must change these values
# ──────────────────────────────────────────────

# Your domain name (no www, no https)
DOMAIN=ephem.health.gov.xx

# PostgreSQL password for the odoo database user
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_TO_SOMETHING_STRONG

# Odoo master password (used to create/manage databases from the web UI)
# Generate with: openssl rand -base64 24
ODOO_ADMIN_PASSWORD=CHANGE_ME_TO_SOMETHING_STRONG

# ──────────────────────────────────────────────
# OPTIONAL — Defaults work for most setups
# ──────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=odoo
POSTGRES_DB=postgres

# Odoo database filtering
# Set to ^%d$ to route subdomains to matching database names
# Leave empty to allow manual database selection
ODOO_DBFILTER=

# Set to False after creating all needed databases
ODOO_LIST_DB=True

# Odoo workers (adjust based on CPU cores: workers = CPU * 2 + 1)
ODOO_WORKERS=4

# Max upload size in MB
NGINX_MAX_BODY_SIZE=100

# Email for SSL certificate registration
SSL_EMAIL=admin@health.gov.xx

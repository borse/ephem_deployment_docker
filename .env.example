# ──────────────────────────────────────────────
# REQUIRED — You must change these three values
# ──────────────────────────────────────────────

# Your domain name (no www, no https)
# Example: ephem.health.gov.ye
DOMAIN=ephem.health.gov.xx

# Database password — generate with: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME

# Odoo master password (for creating/managing databases)
# Generate with: openssl rand -base64 24
ODOO_ADMIN_PASSWORD=CHANGE_ME

# ──────────────────────────────────────────────
# OPTIONAL — Defaults work for most setups
# ──────────────────────────────────────────────

POSTGRES_USER=odoo
POSTGRES_DB=postgres

# Set to False after creating all your databases
ODOO_LIST_DB=True

# Set to ^%d$ if using subdomain-based database routing
ODOO_DBFILTER=

# Email for SSL certificate
SSL_EMAIL=admin@health.gov.xx
